# Local LLM Platform Configuration

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false

# Database
DATABASE_URL=sqlite:///./local_llm_platform.db

# Redis (for Celery queue)
REDIS_URL=redis://localhost:6379/0

# Security (leave empty to disable auth)
API_KEY=
SECRET_KEY=change-me-in-production

# Runtime defaults
DEFAULT_BACKEND=llama_cpp
MAX_LOADED_MODELS=3
MODEL_LOAD_TIMEOUT=300

# Training
TRAINING_WORKER_CONCURRENCY=1
MAX_TRAINING_JOBS=2
